#!/usr/bin/env bash
#
# SnapOut! - Shell entrypoint delegating to Python backend
#

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
PYTHON_BIN="${SNAPOUT_PYTHON:-python3}"

if ! command -v "$PYTHON_BIN" >/dev/null; then
    echo "Error: $PYTHON_BIN command not found" >&2
    exit 1
fi

export PYTHONPATH="$SCRIPT_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m snapout "$@"